# Keep folder structure, ignore pipeline-managed data
/data/raw/*
!/data/raw/.gitkeep
/data/processed/*
!/data/processed/.gitkeep
/data/analysis/*
!/data/analysis/.gitkeep
/data/results/figures/*
!/data/results/figures/.gitkeep
/data/results/tables/*
!/data/results/tables/.gitkeep
